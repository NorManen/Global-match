<!DOCTYPE html><html><head><meta http-equiv="Content-Type" content="text/html; charset=windows-1252"><link rel="stylesheet" type="text/css" href="cid:css-c895da81-eaa2-4437-8847-7f657ad3d5c2@mhtml.blink" />
<title>Global Match v8 Pro</title>

</head>
<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen">
<!-- Login Screen -->
<div id="login-screen" class="min-h-screen flex items-center justify-center p-4">
  <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-12 max-w-md w-full border">
    <div class="text-center mb-8">
      <div class="w-20 h-20 mx-auto bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mb-4">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Global Match</h1>
      <p class="text-slate-600">SEA Recruiter Dashboard</p>
    </div>

    <form id="login-form">
      <div class="space-y-4 mb-6">
        <div>
          <input id="email" type="email" placeholder="Email" class="w-full p-4 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-transparent" required="">
        </div>
        <div>
          <input id="password" type="password" placeholder="Password" class="w-full p-4 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-transparent" required="">
        </div>
      </div>
      <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-600 text-white py-4 px-6 rounded-2xl font-bold text-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">Login</button>
    </form>

    <div class="mt-6 text-center text-sm text-slate-500">
      Admin: admin@globalmatch.com / admin123<br>
      Test: recruiter@test.com / test123
    </div>
  </div>
</div>

<!-- Main App (hidden until login) -->
<div id="app" class="hidden min-h-screen">
  <nav class="bg-white shadow-lg border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <h1 class="text-2xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">Global Match</h1>
        </div>
        <div class="flex items-center space-x-4">
          <span id="user-email" class="font-medium"></span>
          <button id="logout" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-xl text-sm font-medium">Logout</button>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto p-6 md:p-8">
    <div class="grid lg:grid-cols-4 gap-6">
      <!-- Upload Section -->
      <div class="lg:col-span-1 bg-white rounded-3xl shadow-xl p-6 border">
        <h2 class="text-xl font-bold mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 12l2 2 4-4"></path>
          </svg>
          Bulk CV Upload
        </h2>

        <div class="border-2 border-dashed border-slate-300 hover:border-emerald-400 rounded-2xl p-8 text-center cursor-pointer transition-colors mb-6">
          <svg class="w-16 h-16 mx-auto mb-4 text-slate-400 hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          <div class="font-semibold mb-1">Drop CVs here</div>
          <div class="text-sm text-slate-500">PDF/DOCX â€¢ Auto-validates content</div>
        </div>

        <input type="file" id="file-input" multiple="" accept=".pdf,.docx" class="hidden">

        <div id="upload-stats" class="space-y-2 text-sm mb-4 hidden">
          <div class="flex justify-between"><span>Valid CVs:</span><span id="valid-num" class="font-bold text-emerald-600">0</span></div>
          <div class="flex justify-between"><span>Skipped:</span><span id="skip-num" class="font-bold text-orange-600">0</span></div>
          <div class="w-full bg-slate-200 rounded-full h-2">
            <div id="upload-progress" class="bg-emerald-600 h-2 rounded-full w-0"></div>
          </div>
        </div>

        <button id="process-cvs" class="w-full bg-emerald-600 text-white py-3 rounded-xl font-bold hover:bg-emerald-700 disabled:opacity-50" disabled="">Process CVs</button>
      </div>

      <!-- Filters -->
      <div class="lg:col-span-1 bg-white rounded-3xl shadow-xl p-6 border space-y-4">
        <h2 class="text-xl font-bold mb-4">Smart Filters</h2>

        <div>
          <label class="block text-sm font-medium mb-2">Country</label>
          <select id="country-select" class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-emerald-500">
            <option>All Countries</option>
            <option>Laos</option><option>Thailand</option><option>Vietnam</option>
            <option>Philippines</option><option>Indonesia</option>
            <!-- Full 200+ list truncated for demo -->
          </select>
        </div>

        <div><label class="block text-sm font-medium mb-2">Skills</label><input id="skills-input" placeholder="PHP React Zendesk" class="w-full p-3 border rounded-xl"></div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-xs block mb-1 font-medium">Min Salary</label>
            <input id="min-salary" type="number" placeholder="1000" class="w-full p-2 border rounded-lg">
          </div>
          <div>
            <label class="text-xs block mb-1 font-medium">Max Salary</label>
            <input id="max-salary" type="number" placeholder="5000" class="w-full p-2 border rounded-lg">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-xs block mb-1 font-medium">English</label>
            <select id="english-select" class="w-full p-2 border rounded-lg">
              <option>Any</option><option>Basic</option><option>Intermediate</option><option>Fluent</option><option>Native</option>
            </select>
          </div>
          <div>
            <label class="text-xs block mb-1 font-medium">Experience</label>
            <select id="exp-select" class="w-full p-2 border rounded-lg">
              <option>Any</option><option>0-2 years</option><option>2-5 years</option><option>5+ years</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-xs block mb-1 font-medium">Work Mode</label>
            <select id="mode-select" class="w-full p-2 border rounded-lg">
              <option>Any</option><option>Remote</option><option>Relocate</option><option>Contractor</option>
            </select>
          </div>
          <div>
            <label class="text-xs block mb-1 font-medium">Timezone</label>
            <select id="tz-select" class="w-full p-2 border rounded-lg">
              <option>Any</option><option>UTC+7</option><option>UTC+8</option><option>UTC+9</option>
            </select>
          </div>
        </div>

        <button id="clear-btn" class="w-full py-2 px-4 border rounded-xl hover:bg-slate-50 text-sm font-medium">Clear All</button>
        <button id="filter-btn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white py-2 px-4 rounded-xl font-medium text-sm">Apply Filters</button>
      </div>

      <!-- Results + Manual Edit -->
      <div class="lg:col-span-2 bg-white rounded-3xl shadow-xl p-6 border">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold">Candidates <span id="candidate-count">0</span></h2>
          <button id="export" class="bg-emerald-600 text-white px-6 py-2.5 rounded-xl font-medium hover:bg-emerald-700">Export Excel</button>
        </div>

        <div id="candidates-list" class="space-y-4"></div>
      </div>
    </div>
  </div>

  <!-- Data storage (local DB simulation) -->
  


</div></body></html>
