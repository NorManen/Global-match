<!DOCTYPE html><html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-dc7dd754-0f88-4eb9-bf05-26ef371156f2@mhtml.blink" /><link rel="stylesheet" type="text/css" href="cid:css-2f84d24c-0ad8-4cf3-bdbb-6f70b3c73bba@mhtml.blink" />
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global Match v8 - Production</title>
  
  
</head>
<body class="bg-gradient-to-br from-slate-50 to-emerald-50 min-h-screen">

  <!-- Login Screen -->
  <div id="login" class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-white/90 backdrop-blur-xl rounded-3xl shadow-2xl p-8 md:p-12 max-w-sm w-full border border-white/50 max-w-md">
      <div class="text-center mb-8">
        <div class="w-24 h-24 mx-auto gradient rounded-3xl flex items-center justify-center mb-6 shadow-2xl">
          <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-slate-900 mb-3">Global Match</h1>
        <p class="text-slate-600 text-lg">SEA Talent Dashboard</p>
      </div>

      <form id="login-form" class="space-y-6">
        <div>
          <input id="login-email" type="email" placeholder="admin@globalmatch.com" required="" class="w-full p-4 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-emerald-500/20 focus:border-emerald-500 bg-slate-50 transition-all">
        </div>
        <div>
          <input id="login-password" type="password" placeholder="admin123" required="" class="w-full p-4 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-emerald-500/20 focus:border-emerald-500 bg-slate-50 transition-all">
        </div>
        <button type="submit" class="w-full gradient text-white py-4 px-8 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
          Login
        </button>
      </form>

      <div class="mt-6 p-4 bg-slate-50 rounded-2xl text-xs text-slate-600 text-center">
        <strong>Admin:</strong> admin@globalmatch.com / admin123
      </div>
    </div>
  </div>

  <!-- Main App -->
  <div id="app" class="hidden">
    <!-- Top Bar -->
    <nav class="bg-white/80 backdrop-blur-xl shadow-lg border-b sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-4">
        <div class="flex justify-between items-center">
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 gradient rounded-2xl flex items-center justify-center shadow-lg">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">Global Match</h1>
              <p class="text-sm text-slate-600">v8 Production</p>
            </div>
          </div>
          <div class="flex items-center space-x-3">
            <span id="current-user" class="font-semibold text-slate-800 px-3 py-1 bg-slate-100 rounded-xl"></span>
            <button id="logout-btn" class="px-6 py-2 bg-slate-200 hover:bg-slate-300 rounded-xl font-medium text-sm transition-all">Logout</button>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto p-6">
      <div class="grid lg:grid-cols-4 gap-8">

        <!-- Upload Panel -->
        <div class="lg:col-span-1 bg-white/80 backdrop-blur-xl rounded-3xl shadow-xl p-8 border border-white/50">
          <div class="flex items-center mb-6">
            <svg class="w-8 h-8 text-emerald-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 12l2 2 4-4"></path>
            </svg>
            <h2 class="text-2xl font-bold text-slate-900">Bulk Upload</h2>
          </div>

          <div id="upload-area" class="border-2 border-dashed border-slate-300 hover:border-emerald-400 rounded-3xl p-12 text-center cursor-pointer transition-all hover:bg-emerald-50 group mb-8">
            <svg class="w-20 h-20 mx-auto mb-6 text-slate-400 group-hover:text-emerald-500 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <div class="font-bold text-xl mb-2 group-hover:text-emerald-600 transition-colors">Drop CVs Here</div>
            <div class="text-slate-500 mb-4">PDF • DOCX • Auto-validates</div>
            <div class="text-xs text-slate-400">or click to select</div>
          </div>

          <input type="file" id="file-input" multiple="" accept=".pdf,.docx" class="hidden">

          <div id="upload-status" class="space-y-3 text-sm hidden">
            <div class="flex justify-between font-medium">
              <span>Valid CVs:</span>
              <span id="valid-count" class="text-emerald-600 font-bold">0</span>
            </div>
            <div class="flex justify-between text-slate-500">
              <span>Skipped files:</span>
              <span id="skipped-count">0</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3 overflow-hidden">
              <div id="progress-bar" class="bg-gradient-to-r from-emerald-500 to-teal-600 h-3 rounded-full transition-all w-0"></div>
            </div>
          </div>

          <button id="process-btn" class="w-full bg-gradient-to-r from-emerald-600 to-teal-600 text-white py-4 px-6 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all disabled:opacity-50" disabled="">
            Process CVs
          </button>
        </div>

        <!-- Filters Panel -->
        <div class="lg:col-span-1 bg-white/80 backdrop-blur-xl rounded-3xl shadow-xl p-8 border border-white/50 space-y-6">
          <h3 class="text-2xl font-bold text-slate-900 flex items-center">
            <svg class="w-8 h-8 text-emerald-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
            </svg>
            Filters
          </h3>

          <!-- Country -->
          <div>
            <label class="block text-sm font-semibold mb-3 text-slate-700">Country</label>
            <select id="country-filter" class="w-full p-4 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-emerald-500/20 bg-white/50">
              <option>All</option>
              <option>Laos</option>
              <option>Thailand</option>
              <option>Vietnam</option>
              <option>Philippines</option>
              <option>Indonesia</option>
            </select>
          </div>

          <!-- Salary Range -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold mb-2 text-slate-700">Min Salary</label>
              <input id="min-salary" type="number" placeholder="1000" class="w-full p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 bg-white/50">
            </div>
            <div>
              <label class="block text-xs font-semibold mb-2 text-slate-700">Max Salary</label>
              <input id="max-salary" type="number" placeholder="5000" class="w-full p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 bg-white/50">
            </div>
          </div>

          <!-- Quick Filters -->
          <div class="space-y-2">
            <label class="block text-sm font-semibold mb-3 text-slate-700">Quick Filters</label>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <button class="p-3 border border-slate-200 rounded-xl hover:bg-emerald-50 hover:border-emerald-400 transition-all text-left">Laos only</button>
              <button class="p-3 border border-slate-200 rounded-xl hover:bg-emerald-50 hover:border-emerald-400 transition-all text-left">Remote only</button>
              <button class="p-3 border border-slate-200 rounded-xl hover:bg-emerald-50 hover:border-emerald-400 transition-all text-left">Support roles</button>
              <button class="p-3 border border-slate-200 rounded-xl hover:bg-emerald-50 hover:border-emerald-400 transition-all text-left">Fluent English</button>
            </div>
          </div>

          <div class="space-y-3 pt-4 border-t">
            <button id="clear-filters" class="w-full p-3 bg-slate-100 hover:bg-slate-200 rounded-xl font-semibold text-sm transition-all">Clear All</button>
            <button id="apply-filters" class="w-full gradient text-white p-3 rounded-xl font-bold text-lg shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all">
              Apply Filters (0)
            </button>
          </div>
        </div>

        <!-- Candidates Panel -->
        <div class="lg:col-span-2 bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl p-8 border border-white/50">
          <div class="flex justify-between items-center mb-8">
            <h3 class="text-3xl font-bold text-slate-900">
              Candidates 
              <span id="total-count" class="text-emerald-600 font-bold ml-2">0</span>
            </h3>
            <div class="flex gap-3">
              <button id="export-shortlist" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-xl transition-all">
                Export Shortlist
              </button>
              <button id="add-manual" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-xl transition-all">
                Add Manual
              </button>
            </div>
          </div>

          <div id="candidates-container" class="space-y-6">
            <!-- Dynamic candidates will render here -->
            <div class="text-center py-20">
              <svg class="w-24 h-24 mx-auto mb-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <h3 class="text-2xl font-bold text-slate-500 mb-2">No candidates yet</h3>
              <p class="text-slate-500">Upload CVs above to get started</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  


</body></html>
